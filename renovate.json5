{
	// Self-hosted Renovate config for kaelys-js/kaelys-js — the org profile
	// README repo. Scope: npm workspace deps (ajv + ajv-formats + linters
	// pulled through pnpm) + GitHub Actions pinned in .github/workflows/*.
	//
	// mise-managed tools (node, pnpm, yq, gitleaks, yamllint, markdownlint-cli2,
	// oxlint, oxfmt) are pinned in mise.toml and out of scope here — we bump
	// them in lockstep with stardust's mise.toml manually. Container images
	// are not used in this repo, so no dockerfile/custom.regex manager.
	//
	// 1. npm/pnpm deps. The built-in `npm` manager reads package.json +
	//    pnpm-lock.yaml. patch/minor/digest auto-merge after CI; major is a
	//    review PR. lockFileMaintenance refreshes the lock.
	//
	// 2. GitHub Actions. The built-in `github-actions` manager reads every
	//    `uses:` line in .github/workflows/*.yml. Same policy as npm:
	//    patch/minor/digest auto-merge, major review PR.
	//
	// Every Renovate commit is `chore(deps): …`. This repo has no commitlint
	// today, but the message format matches stardust's so a future commitlint
	// adoption doesn't churn Renovate.
	$schema: "https://docs.renovatebot.com/renovate-schema.json",

	extends: [
		"config:recommended",
		":dependencyDashboard",
		":semanticCommits",
		// Keep every GitHub Actions `uses:` line pinned to a full commit SHA
		// with a `# vX.Y.Z` comment. Renovate rewrites the comment when it
		// bumps the pin, so tag context stays visible next to the digest.
		"helpers:pinGitHubActionDigestsToSemver",
	],

	timezone: "America/Vancouver",

	// Same overnight window as stardust so both repos' bots stay off the day.
	schedule: ["* 0-5 * * *"],

	dependencyDashboard: true,

	// --- Commit / PR message shape -------------------------------------------
	// Format matches stardust's Renovate: `chore(deps): update <pkg> to <ver>`.
	// This repo has no commitlint config today, but keeping the shape identical
	// means adopting commitlint later is a no-op for Renovate PRs.
	semanticCommits: "enabled",
	semanticCommitType: "chore",
	semanticCommitScope: "deps",
	commitMessagePrefix: "chore(deps):",

	// --- DCO signoff -----------------------------------------------------------
	// This repo doesn't have probot/dco installed today, but stardust does, and
	// we use the same GitHub App identity across the org. Injecting the trailer
	// here keeps every kaelys-js-renovate[bot] commit consistent — no repo has
	// to know whether DCO is on to render a clean commit.
	commitBody: "Signed-off-by: kaelys-js-renovate[bot] <304942767+kaelys-js-renovate[bot]@users.noreply.github.com>",

	// --- Concurrency / noise control -----------------------------------------
	// Throttle to one open Renovate PR at a time / one new PR per hour so
	// the CI-minutes-per-day floor stays predictable (public repo — Actions
	// minutes are free, but Renovate PR churn still creates review load).
	// Renovate closes over-limit PRs on its next scheduled run.
	prConcurrentLimit: 1,
	prHourlyLimit: 1,
	rebaseWhen: "behind-base-branch",

	// Cool-down: never auto-merge a release younger than this. Guards against
	// a compromised/yanked just-published version landing hands-off.
	minimumReleaseAge: "3 days",

	// Enabled managers:
	//   - npm             -> package.json + pnpm-lock.yaml
	//   - custom.regex    -> mise.toml `node = "..."` + `pnpm = "..."` lines,
	//                       matched with depName == the npm engines depName so
	//                       Renovate groups mise.toml + package.json engines
	//                       into ONE PR (bump-together). Every OTHER tool in
	//                       mise.toml is still bumped in lockstep with stardust
	//                       manually — only node + pnpm are automated here.
	//   - github-actions  -> .github/workflows/*.yml `uses:` lines
	// Everything else stays off — dockerfile doesn't apply here.
	enabledManagers: ["npm", "custom.regex", "github-actions"],

	// --- customManager: mise.toml node + pnpm (bump-together) ----------------
	// See foundation-registry/renovate.json5 for the design rationale. The npm
	// engines depName MUST match `node` / `pnpm` for the group rule below to
	// merge mise.toml + package.json engines into one PR.
	customManagers: [
		{
			customType: "regex",
			managerFilePatterns: ["/^mise\\.toml$/"],
			matchStrings: ['^node\\s*=\\s*"(?<currentValue>[^"]+)"'],
			depNameTemplate: "node",
			packageNameTemplate: "nodejs/node",
			datasourceTemplate: "github-releases",
			versioningTemplate: "node",
			extractVersionTemplate: "^v(?<version>.+)$",
		},
		{
			customType: "regex",
			managerFilePatterns: ["/^mise\\.toml$/"],
			matchStrings: ['^pnpm\\s*=\\s*"(?<currentValue>[^"]+)"'],
			depNameTemplate: "pnpm",
			packageNameTemplate: "pnpm",
			datasourceTemplate: "npm",
			versioningTemplate: "npm",
		},
	],

	// Keep pnpm-lock.yaml fresh (dedupe / transitive security bumps) via a
	// scheduled lockfile-only PR. Auto-merged after CI (see packageRules).
	lockFileMaintenance: {
		enabled: true,
		automerge: true,
		platformAutomerge: true,
	},

	// --- packageRules --------------------------------------------------------
	// Automerge matrix (all automerges gated on green CI + minimumReleaseAge):
	//   npm             patch/minor/digest      -> automerge (grouped)
	//   npm             major                   -> review PR (never grouped)
	//   github-actions  patch/minor/digest      -> automerge (grouped)
	//   github-actions  major                   -> review PR (never grouped)
	//   lockFileMaintenance                     -> automerge (configured above)
	packageRules: [
		// ── node + pnpm bump-together (mise.toml + package.json engines) ────
		{
			// Group mise.toml (custom.regex) + package.json engines (npm) into
			// ONE PR per bump. patch/minor auto-merges (CI validates both
			// files together).
			matchDepNames: ["node", "pnpm"],
			matchManagers: ["custom.regex", "npm"],
			groupName: "node + pnpm toolchain",
			commitMessageTopic: "node + pnpm toolchain",
			matchUpdateTypes: ["patch", "minor", "digest"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: true,
		},
		{
			// Major bumps of node/pnpm are a human decision; review PR.
			matchDepNames: ["node", "pnpm"],
			matchManagers: ["custom.regex", "npm"],
			matchUpdateTypes: ["major"],
			groupName: "node + pnpm toolchain",
			automerge: false,
		},

		// ── npm / pnpm workspace deps ────────────────────────────────────────
		{
			// patch/minor/digest are non-breaking by semver; CI (lint + schema +
			// node --test) fully validates JS deps, so auto-merge after green CI.
			matchManagers: ["npm"],
			matchUpdateTypes: ["patch", "minor", "digest"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: true,
			groupName: "npm dev dependencies (non-major)",
			commitMessageTopic: "npm dev dependencies",
		},
		{
			// Major npm bumps can break; review PR, its own PR (never grouped).
			matchManagers: ["npm"],
			matchUpdateTypes: ["major"],
			automerge: false,
			groupName: null,
		},

		// ── GitHub Actions ───────────────────────────────────────────────────
		{
			// patch/minor/digest bumps for the workflow `uses:` pins auto-merge
			// after green CI. Grouped so a single actions/checkout or mise-action
			// bump lands as one PR across every workflow.
			matchManagers: ["github-actions"],
			matchUpdateTypes: ["patch", "minor", "digest"],
			automerge: true,
			automergeType: "pr",
			platformAutomerge: true,
			groupName: "github actions (non-major)",
			commitMessageTopic: "github actions",
		},
		{
			// Major action bumps (e.g. actions/checkout v4 -> v5) can change
			// input names; review PR, its own PR (never grouped).
			matchManagers: ["github-actions"],
			matchUpdateTypes: ["major"],
			automerge: false,
			groupName: null,
		},
	],
}
