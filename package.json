{
	"name": "kaelys-js-profile",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"description": "kaelys-js GitHub org profile README + cross-repo catalog aggregator.",
	"license": "MIT",
	"engines": {
		"node": ">=26.4.0",
		"pnpm": ">=11.10.0"
	},
	"packageManager": "pnpm@11.12.0",
	"scripts": {
		"lint": "oxlint",
		"lint:secrets": "gitleaks dir --no-banner --redact --exit-code 1 .",
		"lint:yaml": "yamllint -s .",
		"lint:markdown": "markdownlint-cli2 '**/*.md' '#node_modules'",
		"test": "node --test 'tests/**/*.test.mjs'",
		"sync": "node scripts/sync-catalog.mjs",
		"sync:check": "node scripts/sync-catalog.mjs --check",
		"validate:schema": "node scripts/sync-catalog.mjs --schema-check-only"
	},
	"dependencies": {
		"ajv": "8.17.1",
		"ajv-formats": "3.0.1"
	}
}
